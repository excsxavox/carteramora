# --- SQL Server (producción) — mismo formato que script feriados ---
# Si define DATABASE_URL, tiene prioridad sobre DB_*.
# DB_DRIVER=ODBC Driver 18 for SQL Server
# DB_SERVER=.\SQLEXPRESS
# DB_DATABASE=BD_Cobranza
# DB_TRUSTED_CONNECTION=yes
# DB_USER=sa
# DB_PASSWORD=***
# DB_TRUST_SERVER_CERTIFICATE=yes
# DB_ENCRYPT=yes

# SQLite local (desarrollo) — comentar si usa solo DB_*
DATABASE_URL=sqlite:///data/BD_Cobranza.sqlite

# Excel feriados (Job 0b) → tabla catalogo (clave feriados_catalogo)
EXCEL_DIR=data/catalogo
EXCEL_PATTERN=dias_feriados.xlsx
CLAVE_FERIADOS=feriados_catalogo
LOG_DIR=logs

# Excel asesores (Job 0)
ARCHIVO_EXCEL_ASESORES=data/catalogo/asesores.xlsx
SYNC_ASESORES_RECHAZAR_DUPLICADOS=true

# Entradas/salidas — automático por fecha de hoy (MMDDYYYY mes-día-año)
DOCSMORA_DIR=docsmora
DESTINO_DIR=destino
USAR_RUTAS_AUTOMATICAS=true
# FECHA_CORTE=05052026

# API (python main.py api)
# API_HOST=127.0.0.1
# API_PORT=8000
# Rutas manuales (si USAR_RUTAS_AUTOMATICAS=false):
# ARCHIVO_MOROSIDAD=docsmora/2026/05052026/cartera05052026b/camorosico_....lis
# ARCHIVO_CARTERA=docsmora/2026/05052026/cartera05052026b/cadetacaco_....lis

DIAS_MORA_MINIMO=30
USAR_MORA_TEMPRANA=true
MORA_TEMPRANA_DIAS_MIN=1
# 0 = máximo calculado (febrero 28/29, abril 30, etc. + DIA PAGO)
MORA_TEMPRANA_DIAS_MAX=0
USAR_REGLAS_BD=false
ESTADOS_EXCLUIDOS=CASTIGADO,JUDICIAL,GESTION JUDICIAL
TIPOS_OPER_EXCLUIDOS=COMPRA CARTERA,COMPRACARTERA
# ASIGNACION diario: destino/{año}/{MM}/ASIGNACION_{MMDDYYYY}.csv (automático si se omite)
# ARCHIVO_SALIDA_ASIGNACION=destino/2026/06/ASIGNACION_06032026.csv
ARCHIVO_RECBLUE=data/catalogo/recblue_consulta_creditos.xlsx

# Notificaciones por correo ante errores del pipeline
NOTIFICACIONES_ERRORES_HABILITADO=false
ARCHIVO_EXCEL_NOTIFICACIONES=data/catalogo/notificaciones_errores.xlsx
NOTIFICACIONES_ASUNTO_PREFIJO=[Cartera Mora]
# SMTP_HOST=smtp.empresa.com
# SMTP_PORT=587
# SMTP_USER=alertas@cobranza.local
# SMTP_PASSWORD=***
# SMTP_FROM=alertas@cobranza.local
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

LOG_LEVEL=INFO
LOG_MUESTRA_MAPEO=0
PERSISTIR_EN_BD=true
DB_ECHO=false
