flowchart TB
    subgraph entrada [Entradas]
        XLS[data/catalogo/asesores.xlsx]
        XLSF[data/catalogo/*feriados*.xlsx]
        CORE1[docsmora morosidad.lis]
        CORE2[docsmora cartera.lis]
    end

    subgraph pipeline [main.py pipeline - cadena]
        H0[SyncAsesoresHandler]
        H0b[SyncFeriadosHandler]
        H1[LimpiezaHandler]
        H0 --> H0b --> H1
    end

    subgraph job1_interno [Job 1 - cadena limpieza]
        L1[LecturaMorosidad]
        L2[LecturaCartera]
        L3[ProcesamientoMora]
        L4[PersistenciaBD]
        L1 --> L2 --> L3 --> L4
    end

    subgraph job2 [Job 2 staging]
        J2[main.py staging]
    end

    subgraph bd [BD_Cobranza]
        T_AS[asesores]
        T_CL[claves]
        T_CAT[catalogo]
        T_DEU[deudores]
        T_DEUDA[deuda]
        T_AD[asesores_deuda]
        T_TMP[tmp_stg]
    end

    XLS --> H0 --> T_AS
    XLSF --> H0b --> T_CL
    H0b --> T_CAT
    CORE1 --> H1
    CORE2 --> H1
    H1 --> L1
    L4 --> T_DEU
    L4 --> T_DEUDA
    L4 --> T_AD
    H1 --> J2
    J2 --> T_TMP
